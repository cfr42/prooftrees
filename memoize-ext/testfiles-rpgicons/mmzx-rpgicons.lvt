\DocumentMetadata{
  lang=en-GB,
  pdfversion=2.0,
  pdfstandard=UA-2,
  tagging=on,
}
\RequirePackage{svn-prov}
\ProvidesFileSVN{$Id: mmzx-rpgicons.lvt 11784 2026-03-17 17:30:47Z cfrees $}[v0.0 \revinfo][\filebase: test]
\input regression-test.tex\relax
\documentclass{article}
\usepackage[extract=python]{memoize}
\ExplSyntaxOn
\tl_set:Ne \mmzpdfmajorverion { \pdf_version_major: }
\tl_set:Ne \mmzpdfminorverion { \pdf_version_minor: }
\ExplSyntaxOff
\mmzset{prefix=memos/,
  include context in ccmemo,
  trace,
}
\usepackage{rpgicons}
\rpgiconsset{%
  every wisdom = {%
    variant = 1,
  },
}
\title{memoize-ext: rpgicons}
\begin{document}
\START
\TEST{rpgicons-tag}{%
  \ability{wisdom}%
}
\SHOWPDFTAGS
\OMIT
\end{document}
