\usepackage{tikz}
\title{memoize-ext: talk w tagging}
\begin{document}
\TIMO
\TESTMEMOIZATION*{tikzpicture-alt}{%
  \begin{frame}
    \frametitle{Frame 1}
    \begin{tikzpicture}[alt=start of alphabet]
      \node {abc};
    \end{tikzpicture}%
  \end{frame}
}{projector-13323D17A05258C3FB7F8F39CA70E9FB}{E778DCCCB8AAB0BBD3F6CFEEFD2421F8}
\TESTMEMOIZATION*{tikzpicture-ts}{%
  \begin{frame}
    \frametitle{Frame 2}
    \begin{tikzpicture}[tagging-setup={alt=beginning of alphabet}]
      \node {abc};
    \end{tikzpicture}%
  \end{frame}
}{projector-D4BCF8AA2F98AF6F9E153079ECBA7966}{E778DCCCB8AAB0BBD3F6CFEEFD2421F8}
\TESTMEMOIZATION*{tikzpicture-actualtext}{%
