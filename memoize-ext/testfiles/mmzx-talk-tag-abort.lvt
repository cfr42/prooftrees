\DocumentMetadata{%
  tagging=on,
  lang=en-GB,
  pdfversion=2.0,
  pdfstandard=UA-2,
  uncompress,
}
\RequirePackage{svn-prov}
\ProvidesFileSVN{$Id: mmzx-talk-tag-abort.lvt 11725 2026-03-04 02:41:52Z cfrees $}[v0.0 \revinfo][\filebase: test]
\input regression-test.tex\relax
\documentclass{ltx-talk}
\RequirePackage{memoize-ext-debug}
\input{mmzx-support.cfg}
\START
\TESTMMZ
\OMIT
\mmzset{prefix=memos/,include context in ccmemo,trace,talk mode to prefix}
\usepackage{tikz}
\title{memoize-ext: talk w tagging - abortions}
\begin{document}
\TIMO
\TEST{tikzpicture-unsupported}{%
  \begin{frame}
    \frametitle{Frame 1}
    \begin{tikzpicture}
      \node {Memoization should abort};
    \end{tikzpicture}%
  \end{frame}
}
\TEST{tikzpicture-remember}{%
  \begin{frame}
    \frametitle{Frame 2}
    \begin{tikzpicture}[alt=remember picture,remember picture]
      \node {This picture should be remembered.};
    \end{tikzpicture}%
  \end{frame}
}
\SHOWPDFTAGS
\OMIT
\end{document}
